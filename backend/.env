# AgroLens AI — Environment Variables
# Copy file ini jadi .env dan isi nilainya

# ── Database ──────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=agrolens_database

# ── JWT Auth ──────────────────────────────
SECRET_KEY=your-super-secret-key-ganti-ini-sekarang
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── ML Models Path ────────────────────────
MODEL_DIR=./ml_models/

# ── External APIs ─────────────────────────
GROQ_API_KEY=your-groq-api-key-here
BMKG_API_URL=https://api.bmkg.go.id/publik/prakiraan-cuaca

# ── App ───────────────────────────────────
APP_ENV=development
DEBUG=True